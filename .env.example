# ===========================================
# NEW BALAJI BANGLES & FANCY - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# For frontend, use .env in the frontend folder with VITE_ prefix.

# ----- Backend (.env in project root or backend) -----
PORT=5000
MONGODB_URI=mongodb://localhost:27017/womens-emporium
# For production: mongodb+srv://user:pass@cluster.mongodb.net/new-balaji-bangles-fancy

JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Default admin credentials (used by scripts/createAdmin.js if ADMIN_EMAIL / ADMIN_PASSWORD not set)
# ADMIN_EMAIL=admin@newbalajibanglesfancy.com
# ADMIN_PASSWORD=admin123

# Cloudinary (for product image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional: allow frontend origin for CORS (e.g. Vercel URL)
FRONTEND_URL=http://localhost:5173

# Store info used in backend-generated invoices / confirmations
STORE_PHONE=+91 78427 14999
STORE_ADDRESS=94, Theertha Katta St, T. K street, Tirupati, Andhra Pradesh 517501

# ----- Frontend (frontend/.env) -----
# Use VITE_ prefix so Vite exposes them to the client.

# API base URL (use full backend URL in production, e.g. https://your-api.onrender.com)
VITE_API_URL=http://localhost:5000/api

# WhatsApp business number (with country code, no + or spaces for URL)
# Example: 919876543210
VITE_WHATSAPP_NUMBER=917842714999

# Contact page
VITE_STORE_PHONE=+91 78427 14999
VITE_STORE_ADDRESS=94, Theertha Katta St, T. K street, Tirupati, Andhra Pradesh 517501

# Google Maps embed URL for Contact page (optional)
# Get from Google Maps: Share -> Embed a map -> copy src URL
# VITE_GOOGLE_MAP_EMBED=https://www.google.com/maps/embed?pb=...
